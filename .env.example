# ============================================================================
# video_me Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control (already in .gitignore).

# ── HuggingFace Token (REQUIRED for Flux 2.0 Dev download) ─────────────────
# Get token: https://huggingface.co/settings/tokens
# Accept license: https://huggingface.co/black-forest-labs/FLUX.2-dev
HF_TOKEN=hf_REPLACE_WITH_YOUR_TOKEN_HERE

# ── GPU Runtime Settings ────────────────────────────────────────────────────
VIDEO_ME_WHISPER_DEVICE=cuda
VIDEO_ME_WHISPER_COMPUTE_TYPE=float16
VIDEO_ME_WHISPER_MODEL_SIZE=medium

# ── LLM + VLM (qwen3.6:35b for all stages) ──────────────────────────────────
VIDEO_ME_LLM_MODEL=qwen3.6:35b
VIDEO_ME_LLM_BASE_URL=http://localhost:11434/v1
VIDEO_ME_CRITIQUE_MODEL=qwen3.6:35b
VIDEO_ME_CRITIQUE_BASE_URL=http://localhost:11434/v1

# ── Adapter Selection ───────────────────────────────────────────────────────
VIDEO_ME_RENDER_ADAPTER=comfyui_flux
VIDEO_ME_VIDEO_ADAPTER=ltx
VIDEO_ME_TTS_ADAPTER=fish_s2

# ── Service URLs ────────────────────────────────────────────────────────────
VIDEO_ME_COMFYUI_BASE_URL=http://localhost:8188
VIDEO_ME_FISH_S2_BASE_URL=http://localhost:8025

# ── Language ────────────────────────────────────────────────────────────────
VIDEO_ME_TARGET_LANGUAGE=en

# ── Storage (local dev default) ─────────────────────────────────────────────
VIDEO_ME_JOB_STORE=sqlite
VIDEO_ME_ARTIFACT_STORE=local

# ── PostgreSQL + S3 (optional, production) ──────────────────────────────────
# VIDEO_ME_JOB_STORE=postgres
# VIDEO_ME_ARTIFACT_STORE=s3
# VIDEO_ME_POSTGRES_DSN=postgresql://video_me:video_me_dev@localhost:5432/video_me
# VIDEO_ME_S3_ENDPOINT_URL=http://localhost:9000
# VIDEO_ME_S3_BUCKET=video-me-artifacts
# VIDEO_ME_S3_ACCESS_KEY_ID=video_me
# VIDEO_ME_S3_SECRET_ACCESS_KEY=video_me_dev_password
# VIDEO_ME_S3_REGION=us-east-1

# ── Approval Gates ──────────────────────────────────────────────────────────
VIDEO_ME_AUTO_APPROVE_PLAN=false
VIDEO_ME_AUTO_APPROVE_IMAGES=false

# See .env (created from this template) for full configuration options.
