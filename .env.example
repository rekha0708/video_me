# ============================================================================
# video_me Environment Configuration Template
# ============================================================================
# Copy to .env and fill in your values:  cp .env.example .env
# .env is git-ignored — NEVER commit it or any token. Rotate any leaked token.
# All variables below show their defaults; only HF_TOKEN must be set for GPU runs.
# Full deploy walkthrough: DEPLOY.md   ·   Project context: CLAUDE.md

# ── HuggingFace token (REQUIRED to download gated Flux 2.0 weights) ──────────
# 1. Accept the license: https://huggingface.co/black-forest-labs/FLUX.2-dev
# 2. Create a fine-grained, READ-ONLY token (gated-repo read access):
#    https://huggingface.co/settings/tokens
# 3. Paste it below (starts with hf_). Verify: source .env && echo $HF_TOKEN
HF_TOKEN=hf_REPLACE_WITH_YOUR_TOKEN_HERE

# ── Adapter selection (default stack: musubi_flux / ltx / fish_s2) ───────────
# Image: ComfyUI cannot load Flux 2.0 locally, so the default runs musubi-tuner.
VIDEO_ME_RENDER_ADAPTER=musubi_flux      # or: comfyui_flux (needs BFL cloud API), a1111
VIDEO_ME_VIDEO_ADAPTER=ltx               # or: wan
VIDEO_ME_TTS_ADAPTER=fish_s2             # or: chatterbox

# ── Service URLs ────────────────────────────────────────────────────────────
VIDEO_ME_LLM_BASE_URL=http://localhost:11434/v1     # Ollama (LLM + VLM critique)
VIDEO_ME_CRITIQUE_BASE_URL=http://localhost:11434/v1
VIDEO_ME_COMFYUI_BASE_URL=http://localhost:8188     # ComfyUI (LTX video; also comfyui_flux fallback)
VIDEO_ME_FISH_S2_BASE_URL=http://localhost:8025     # Fish Audio S2 TTS
# Legacy fallback URLs (only when the matching *_ADAPTER override is set):
# VIDEO_ME_SD_BASE_URL=http://localhost:7860         # a1111
# VIDEO_ME_TTS_BASE_URL=http://localhost:8020        # chatterbox
# VIDEO_ME_WAN_BASE_URL=http://localhost:8030        # wan
# VIDEO_ME_LIPSYNC_BASE_URL=http://localhost:8040    # musetalk (wan path)

# ── Models (single multimodal model for LLM + all critique) ─────────────────
VIDEO_ME_LLM_MODEL=qwen3.6:35b           # rollback: qwen3:14b
VIDEO_ME_CRITIQUE_MODEL=qwen3.6:35b
VIDEO_ME_IMAGE_CRITIQUE_MODEL=qwen3.6:35b

# ── GPU / transcription settings ────────────────────────────────────────────
VIDEO_ME_WHISPER_DEVICE=cuda             # cpu for local testing
VIDEO_ME_WHISPER_COMPUTE_TYPE=float16    # int8 on CPU
VIDEO_ME_WHISPER_MODEL_SIZE=medium

# ── Language ────────────────────────────────────────────────────────────────
VIDEO_ME_TARGET_LANGUAGE=en              # en | hi | both (runs the pipeline twice)

# ── Approval gates + critique ───────────────────────────────────────────────
VIDEO_ME_AUTO_APPROVE_PLAN=false         # true to skip the storyboard gate (CI)
VIDEO_ME_AUTO_APPROVE_IMAGES=false       # true to skip the image gate (CI)
VIDEO_ME_APPROVAL_PORT=8765
VIDEO_ME_MAX_PLAN_ITERATIONS=3
VIDEO_ME_IMAGE_CANDIDATES=3              # images rendered per shot before critique

# ── Directories (defaults are repo-relative) ────────────────────────────────
# VIDEO_ME_DATA_DIR=.local               # job working dirs
# VIDEO_ME_REVIEW_DIR=review             # published videos
# VIDEO_ME_LORA_DIR=loras                # LoRA weights
# VIDEO_ME_VOICE_DIR=voices              # voice reference files
# VIDEO_ME_FEEDBACK_LOG_DIR=assets/kids_duo

# ── Storage (local dev defaults) ────────────────────────────────────────────
VIDEO_ME_JOB_STORE=sqlite                # or: postgres
VIDEO_ME_ARTIFACT_STORE=local            # or: s3
# Production (PostgreSQL + S3/MinIO):
# VIDEO_ME_POSTGRES_DSN=postgresql://user:pass@host:5432/video_me
# VIDEO_ME_S3_ENDPOINT_URL=https://s3.amazonaws.com
# VIDEO_ME_S3_BUCKET=video-me-artifacts
# VIDEO_ME_S3_ACCESS_KEY_ID=your-key
# VIDEO_ME_S3_SECRET_ACCESS_KEY=your-secret
# VIDEO_ME_S3_REGION=us-east-1

# ── Troubleshooting ─────────────────────────────────────────────────────────
# echo $HF_TOKEN empty?        → run: source .env
# Flux download 403 / license  → accept license + give the token gated-repo read access
# Verify config + services     → python -m scripts.check_runtime_readiness
