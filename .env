# ============================================================================
# video_me Environment Configuration
# ============================================================================
# This file is git-ignored. Never commit secrets to version control.
# Copy this file to .env and fill in your actual values.

# ── HuggingFace Token ───────────────────────────────────────────────────────
# Required for downloading Flux 2.0 Dev (gated model)
# Get token from: https://huggingface.co/settings/tokens
# Permissions needed: Read + Access to gated repos
# Accept license at: https://huggingface.co/black-forest-labs/FLUX.2-dev
HF_TOKEN=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

# ── GPU Runtime Settings ────────────────────────────────────────────────────
# Whisper transcription (use cuda on GPU machines)
VIDEO_ME_WHISPER_DEVICE=cuda
VIDEO_ME_WHISPER_COMPUTE_TYPE=float16
VIDEO_ME_WHISPER_MODEL_SIZE=medium

# ── LLM + VLM (single model for everything) ─────────────────────────────────
# qwen3.6:35b handles: LLM text generation + image critique + video critique
VIDEO_ME_LLM_MODEL=qwen3.6:35b
VIDEO_ME_LLM_BASE_URL=http://localhost:11434/v1
VIDEO_ME_LLM_API_KEY=ollama

VIDEO_ME_CRITIQUE_MODEL=qwen3.6:35b
VIDEO_ME_CRITIQUE_BASE_URL=http://localhost:11434/v1
VIDEO_ME_CRITIQUE_API_KEY=ollama

VIDEO_ME_IMAGE_CRITIQUE_MODEL=qwen3.6:35b
VIDEO_ME_IMAGE_CRITIQUE_BASE_URL=http://localhost:11434/v1
VIDEO_ME_IMAGE_CRITIQUE_API_KEY=ollama

# ── Adapter Selection (default: comfyui_flux + ltx + fish_s2) ──────────────
VIDEO_ME_RENDER_ADAPTER=comfyui_flux
VIDEO_ME_VIDEO_ADAPTER=ltx
VIDEO_ME_TTS_ADAPTER=fish_s2

# ── Service URLs (default stack) ────────────────────────────────────────────
VIDEO_ME_COMFYUI_BASE_URL=http://localhost:8188
VIDEO_ME_FISH_S2_BASE_URL=http://localhost:8025

# ── Fallback Service URLs (only if using fallback adapters) ─────────────────
# Uncomment and set these if using fallback adapters:
# VIDEO_ME_SD_BASE_URL=http://localhost:7860          # A1111 (RENDER_ADAPTER=a1111)
# VIDEO_ME_TTS_BASE_URL=http://localhost:8020         # Chatterbox (TTS_ADAPTER=chatterbox)
# VIDEO_ME_WAN_BASE_URL=http://localhost:8030         # Wan (VIDEO_ADAPTER=wan)
# VIDEO_ME_LIPSYNC_BASE_URL=http://localhost:8040     # MuseTalk (VIDEO_ADAPTER=wan)

# ── Language Selection ──────────────────────────────────────────────────────
# Options: en (English), hi (Hindi), both (runs pipeline twice)
VIDEO_ME_TARGET_LANGUAGE=en

# ── Directories ─────────────────────────────────────────────────────────────
VIDEO_ME_DATA_DIR=.local
VIDEO_ME_ARTIFACT_DIR=.local/artifacts
VIDEO_ME_REVIEW_DIR=review
VIDEO_ME_LORA_DIR=loras
VIDEO_ME_VOICE_DIR=voices

# ── Storage Backend (local dev default: sqlite + local filesystem) ──────────
VIDEO_ME_JOB_STORE=sqlite
VIDEO_ME_ARTIFACT_STORE=local

# ── PostgreSQL + S3 (optional, for production) ──────────────────────────────
# Uncomment to use PostgreSQL + MinIO/S3 instead of SQLite + local files:
# VIDEO_ME_JOB_STORE=postgres
# VIDEO_ME_ARTIFACT_STORE=s3
# VIDEO_ME_POSTGRES_DSN=postgresql://video_me:video_me_dev@localhost:5432/video_me
# VIDEO_ME_S3_ENDPOINT_URL=http://localhost:9000
# VIDEO_ME_S3_BUCKET=video-me-artifacts
# VIDEO_ME_S3_ACCESS_KEY_ID=video_me
# VIDEO_ME_S3_SECRET_ACCESS_KEY=video_me_dev_password
# VIDEO_ME_S3_REGION=us-east-1

# ── Plan Critique + Approval Gates ──────────────────────────────────────────
VIDEO_ME_MAX_PLAN_ITERATIONS=3
VIDEO_ME_AUTO_APPROVE_PLAN=false
VIDEO_ME_AUTO_APPROVE_IMAGES=false
VIDEO_ME_APPROVAL_PORT=8765
VIDEO_ME_APPROVAL_TIMEOUT_HOURS=24.0

# ── Image Candidate Generation + Critique ───────────────────────────────────
VIDEO_ME_IMAGE_CANDIDATES=3
VIDEO_ME_FEEDBACK_LOG_DIR=assets/kids_duo

# ── CI/Testing Overrides ────────────────────────────────────────────────────
# Set to true for automated CI runs (skips human approval gates)
# VIDEO_ME_AUTO_APPROVE_PLAN=true
# VIDEO_ME_AUTO_APPROVE_IMAGES=true
# VIDEO_ME_RENDER_ALLOW_PLACEHOLDER_LORA=true

# ── Advanced Settings ───────────────────────────────────────────────────────
VIDEO_ME_MAX_REGENERATIONS=3
VIDEO_ME_FFMPEG_BIN=ffmpeg
VIDEO_ME_FFPROBE_BIN=ffprobe

# ============================================================================
# Notes:
# - HF_TOKEN is REQUIRED for Flux 2.0 Dev download during setup_gpu.sh
# - Default stack needs: Ollama + ComfyUI + Fish Audio S2
# - Fallback services (A1111, Wan, MuseTalk) are opt-in via setup flags
# - All paths are relative to project root unless absolute
# - See README.md for full configuration documentation
# ============================================================================
