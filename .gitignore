.DS_Store
.env
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.local/
.docker-config/
dist/
build/
*.egg-info/

# Track B generated/runtime assets.
# Final LoRAs are tracked via Git LFS (see .gitattributes).
# Intermediate checkpoints and smoke-test weights are excluded.
loras/*-step*.safetensors
loras/*-step*.pt
loras/*-step*.ckpt
loras/*_smoke.safetensors
# Voice reference files — tracked in git (small WAVs, ~1 MB each).
# Exclude any large generated/session audio that lands here.
voices/**/*.flac

# Local training output logs. Model weights are ignored above.
training_logs/
